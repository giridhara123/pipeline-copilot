# Copy this to .env and fill in real values. Never commit .env to git.

# Slack — from api.slack.com/apps → your app
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Which Slack channel to post events to (name only, no #)
SLACK_CHANNEL=general

# Set to "github" when real webhooks are wired (Phase 1). Use "fake" for now.
PROVIDER=fake

# GitHub — fill in during Phase 1
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Database — fill in during Phase 2
DATABASE_URL=postgres://user:pass@localhost:5432/pipelinecopilot?sslmode=disable

# AI Service — fill in during Phase 1
AI_SERVICE_URL=http://localhost:8000